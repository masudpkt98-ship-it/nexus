# NEXUS — Docker Compose overrides
# Copy to `.env` (same folder as docker-compose.yml) and adjust as needed.
# Every value below has a safe default in docker-compose.yml, so `docker compose
# up` works with NO .env file. Override here for custom ports, credentials, or AI.

# --- Application ---
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Leave APP_KEY empty to auto-generate an ephemeral key on each boot. Set a
# stable "base64:..." key (php artisan key:generate --show) to persist encrypted
# data/sessions across restarts.
APP_KEY=

# --- Database (PostgreSQL) ---
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=nexus
DB_PORT_HOST=5433

# --- Host port mappings ---
API_PORT=8000
WEB_PORT=3000

# --- Frontend build ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- AI (optional) ---
# Set a real key to enable the Claude-powered AI Assistant; without it the app
# uses the deterministic rule-based fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
