# =============================================================================
# Laravel API — PRODUCTION env template. Copy to api.env.production and fill in.
# Never commit the real file (secrets). Generate APP_KEY with:
#   php artisan key:generate --show
# =============================================================================

APP_NAME=NEXUS
APP_ENV=production
APP_KEY=                       # base64:... (php artisan key:generate --show)
APP_DEBUG=false                # NEVER true in production (leaks stack traces)
APP_URL=https://nexus.example.com

# Frontend origin — used by CORS + Sanctum. Same-origin deploy = the app URL.
FRONTEND_URL=https://nexus.example.com

# --- Session / cookie hardening (HTTPS only) ---------------------------------
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true      # cookies only sent over HTTPS
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# --- Database (Postgres from docker-compose) ---------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=change-me-strong    # also set as DB_PASSWORD for compose

# --- Rate limiter / cache store ----------------------------------------------
CACHE_STORE=database            # throttle counters survive; use redis at scale

# --- Trusted proxy is handled in bootstrap/app.php (trustProxies at:'*') ------
# Only expose the API through Caddy/Cloudflare — never bind it publicly direct.

LOG_CHANNEL=stack
LOG_LEVEL=warning
